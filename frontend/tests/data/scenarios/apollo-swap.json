{
  "id": "apollo_swap_basic",
  "name": "Apollo基础换位测试",
  "description": "测试Apollo神卡与敌方工人交换位置的基本能力",
  "version": "1.0",
  "tags": ["apollo", "swap", "god-card", "basic"],
  "setup": {
    "players": {
      "player1": {
        "name": "Apollo_Alice",
        "godCard": "Apollo"
      },
      "player2": {
        "name": "Normal_Bob", 
        "godCard": "Demeter"
      }
    },
    "boardSize": {
      "width": 5,
      "height": 5
    }
  },
  "moves": [
    {
      "step": 1,
      "type": "place_worker",
      "player": "player1",
      "to": {"x": 1, "y": 0},
      "metadata": {
        "workerIndex": 0,
        "description": "Alice放置第一个工人在(1,0)"
      }
    },
    {
      "step": 2,
      "type": "place_worker", 
      "player": "player1",
      "to": {"x": 2, "y": 1},
      "metadata": {
        "workerIndex": 1,
        "description": "Alice放置第二个工人在(2,1)"
      }
    },
    {
      "step": 3,
      "type": "place_worker",
      "player": "player2", 
      "to": {"x": 1, "y": 1},
      "metadata": {
        "workerIndex": 0,
        "description": "Bob放置第一个工人在(1,1)，与Alice的工人相邻"
      }
    },
    {
      "step": 4,
      "type": "place_worker",
      "player": "player2",
      "to": {"x": 3, "y": 3}, 
      "metadata": {
        "workerIndex": 1,
        "description": "Bob放置第二个工人在(3,3)"
      }
    },
    {
      "step": 5,
      "type": "special_action",
      "player": "player1",
      "from": {"x": 1, "y": 0},
      "to": {"x": 1, "y": 1},
      "metadata": {
        "description": "Apollo使用换位能力，与Bob的工人交换位置",
        "specialAbility": "swap_positions",
        "targetPlayer": "player2"
      }
    }
  ],
  "expectedOutcome": {
    "gameState": "in_progress",
    "boardState": {
      "1,0": {"worker": {"player": "player2", "index": 0}},
      "1,1": {"worker": {"player": "player1", "index": 0}},
      "2,1": {"worker": {"player": "player1", "index": 1}},
      "3,3": {"worker": {"player": "player2", "index": 1}}
    }
  },
  "metadata": {
    "author": "Test Team",
    "created": "2024-01-01",
    "difficulty": "basic",
    "estimatedDuration": "30s"
  }
}